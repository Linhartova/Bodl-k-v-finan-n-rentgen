# Zkopíruj tento soubor na .env.local a vyplň hodnoty.

# --- Anthropic (OCR / extrakce dat ze smlouvy) ---
ANTHROPIC_API_KEY=sk-ant-...
# Volitelně přepiš model (default: claude-sonnet-4-6)
ANTHROPIC_MODEL=claude-sonnet-4-6

# --- Referenční tržní sazba pro výpočet úspory (v %) ---
# Default 4.5 %. Uprav podle aktuální nabídky na trhu.
MARKET_RATE=4.5

# --- Pipedrive (kam padá lead) ---
PIPEDRIVE_API_TOKEN=
# Doména tvé Pipedrive instance, např. mojefirma (z mojefirma.pipedrive.com)
PIPEDRIVE_DOMAIN=
